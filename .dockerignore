# EquiPilot AI - Docker Ignore Rules
# Exclude development and unnecessary files from Docker build context

# Version control
.git/
.gitignore
.gitattributes

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl

# Virtual environments
.venv/
venv/
env/
ENV/
.venv*

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Environment files
.env
.env.local
.env.*.local

# Testing
.pytest_cache/
.coverage
htmlcov/
.coverage.*
*.cover
.cache/
test-results/

# Documentation
docs/
*.md
!README.md

# Docker
.dockerignore
Dockerfile
docker-compose*.yml

# Logs
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp


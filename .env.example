# EquiPilot AI - Environment Variables Template
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED: OpenAI API Configuration
# =============================================================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Model for report synthesis (higher quality)
OPENAI_MODEL=gpt-4o

# Model for classification/sentiment (cost-effective)
OPENAI_MODEL_MINI=gpt-4o-mini

# =============================================================================
# OPTIONAL: News API Configuration
# =============================================================================
# Choose one provider and uncomment the relevant section

# Option 1: NewsAPI.org (https://newsapi.org/register)
# NEWS_API_KEY=your-newsapi-key
# NEWS_API_PROVIDER=newsapi

# Option 2: Alpha Vantage (https://www.alphavantage.co/support/#api-key)
# NEWS_API_KEY=your-alphavantage-key
# NEWS_API_PROVIDER=alphavantage

# Option 3: Finnhub (https://finnhub.io/register)
# NEWS_API_KEY=your-finnhub-key
# NEWS_API_PROVIDER=finnhub

# =============================================================================
# OPTIONAL: Application Configuration
# =============================================================================
# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true

# Frontend
FRONTEND_PORT=8501

# API
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# =============================================================================
# OPTIONAL: Data Source Configuration
# =============================================================================
# yfinance cache TTL in seconds (default: 5 minutes)
YFINANCE_CACHE_TTL=300

# Request timeouts (seconds)
MARKET_DATA_TIMEOUT=30
NEWS_API_TIMEOUT=30
LLM_API_TIMEOUT=60

# Rate limiting
MAX_CONCURRENT_REQUESTS=10
REQUEST_RATE_LIMIT=100  # requests per minute

# =============================================================================
# OPTIONAL: Logging & Monitoring
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json  # or "text"

# =============================================================================
# OPTIONAL: Feature Flags
# =============================================================================
ENABLE_CACHING=true
ENABLE_SENTIMENT_ANALYSIS=true
ENABLE_NEWS_FETCHING=true
# EquiPilot AI - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Deployment Environment
# =============================================================================
ENVIRONMENT=development          # development, staging, or production

# =============================================================================
# OpenAI Configuration (REQUIRED for LLM features)
# =============================================================================
OPENAI_API_KEY=                 # Your OpenAI API key
OPENAI_MODEL=gpt-4o             # Primary model for report synthesis
OPENAI_MODEL_MINI=gpt-4o-mini   # Cost-effective model for classification/sentiment

# =============================================================================
# News API Configuration (OPTIONAL - uses fallback if not set)
# =============================================================================
NEWS_API_KEY=                   # Your News API key (NewsAPI, Alpha Vantage, or Finnhub)
NEWS_API_PROVIDER=newsapi       # newsapi, alphavantage, or finnhub

# =============================================================================
# Backend Server Configuration
# =============================================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true             # true for development, false for production
BACKEND_WORKERS=2               # Number of uvicorn workers (1-8)

# =============================================================================
# Frontend Configuration
# =============================================================================
FRONTEND_PORT=8501

# =============================================================================
# API Configuration
# =============================================================================
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:8501","http://localhost:3000"]

# =============================================================================
# Rate Limiting & Concurrency
# =============================================================================
MAX_CONCURRENT_REQUESTS=10
REQUEST_RATE_LIMIT=100          # Requests per minute

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_CACHING=true
ENABLE_SENTIMENT_ANALYSIS=true
ENABLE_NEWS_FETCHING=true

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=INFO                  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json                 # json (production) or text (development)

# =============================================================================
# Security Configuration
# =============================================================================
SECRET_KEY=                     # Secret key for session signing (REQUIRED in production)